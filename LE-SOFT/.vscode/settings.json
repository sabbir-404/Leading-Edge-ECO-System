{
  // Tell VS Code to exclude the compiled Electron bundles from its file watcher
  // and TypeScript language service. These are build artifacts generated by esbuild
  // and should never be edited directly. Editing them would be overwritten on next build.
  "files.exclude": {
    "core/main.cjs": true,
    "core/preload.cjs": true
  },
  "search.exclude": {
    "core/**": true,
    "resource/assets/**": true,
    "node_modules/**": true,
    "dist/**": true,
    "dist-electron/**": true,
    "release/**": true
  },
  // Prevent TypeScript from trying to type-check compiled .cjs bundles
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true
}
