{
  "name": "le-soft",
  "private": true,
  "version": "1.3.4",
  "description": "Leading Edge ECO-System Software",
  "author": "Leading Edge <leadingedge.com.bd>",
  "type": "module",
  "main": "core/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron:build": "esbuild electron/main.ts --bundle --platform=node --target=node18 --external:electron --external:better-sqlite3 --external:bcryptjs --external:electron-updater --outfile=core/main.cjs && esbuild electron/preload.ts --bundle --platform=node --target=node18 --external:electron --outfile=core/preload.cjs && electron .",
    "electron:dev": "concurrently -k \"vite\" \"npm run electron:build\"",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dist": "node build-electron.cjs && electron-builder --win",
    "dist:mac": "node build-electron.cjs && electron-builder --mac",
    "dist:publish": "node build-electron.cjs && electron-builder --win -p always",
    "dist:mac:publish": "node build-electron.cjs && electron-builder --mac -p always",
    "dist:all": "node build-electron.cjs && electron-builder --win --mac"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@supabase/supabase-js": "^2.97.0",
    "asmcrypto.js": "^2.3.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.34.0",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.363.0",
    "mysql2": "^3.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "tailwind-merge": "^3.4.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "javascript-obfuscator": "^5.3.0",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.leadingedge.lesoft",
    "productName": "LESOFT",
    "icon": "Logo/icon.icns",
    "directories": {
      "output": "release"
    },
    "files": [
      "resource/**/*",
      "core/**/*"
    ],
    "extraResources": [
      {
        "from": "Logo",
        "to": "Logo",
        "filter": [
          "**/*.png"
        ]
      }
    ],
    "afterPack": "./afterPack.cjs",
    "win": {
      "target": "nsis",
      "icon": "../icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "LESOFT",
      "installerIcon": "../icon.ico",
      "uninstallerIcon": "../icon.ico",
      "installerHeaderIcon": "../header.bmp",
      "installerSidebar": "../Sidebar Image.bmp",
      "uninstallerSidebar": "../Sidebar Image.bmp",
      "license": "LICENSE.txt",
      "include": "build/uninstall.nsh"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "Logo/icon.icns"
    },
    "publish": {
      "provider": "github",
      "owner": "sabbir-404",
      "repo": "Leading-Edge-ECO-System"
    }
  }
}